# TheGame Deployment Configuration
# Domain configuration
DOMAIN=thegame.vinsot.fr

# Docker registry settings — use private registry.methodinfo.fr
REGISTRY_URL=registry.methodinfo.fr
REPO_NAME=thegame

# Build settings
VERSION=1.1
BRANCH=main

# Swarm deployment settings
SWARM_STACK_NAME=thegame

# Compose file path (relative to project root)
COMPOSE_FILE=devops/docker-compose.swarm.yml